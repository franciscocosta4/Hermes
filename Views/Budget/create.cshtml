@model Hermes.Models.CreateBudgetViewModel
@{
    Layout = "_Layout";
}
<div class="main-content" style="max-width:600px;">
    <div class="card">
        <h3>Add a spending budget for a specific month.</h3>
        <small style="margin-top:10px;">
            you will be alerted if you are close to the budget!!
        </small> 
        <br/>
        <br />
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            @* <div class="form-group"><label>Source</label><input name="source" placeholder="Salary / Freelance"
            required>
            </div> *@
            <div name="Month" class="form-group"><label asp-for="Month">Month</label>
                <select name="Month"" class="form-control">
                        <option value="1" >
                            January
                        </option>
                        <option value="2">
                            February
                        </option>
                        <option value="3">
                            March
                        </option>
                        <option value="4">
                            April
                        </option>
                        <option value="5">
                            May
                        </option>
                        <option value="6">
                            June
                        </option>
                        <option value="7">
                            July
                        </option>
                        <option value="8">
                            August
                        </option>
                        <option value="9">
                            September
                        </option>
                        <option value="10">
                            October
                        </option>
                        <option value="11">
                            November
                        </option>
                        <option value="12">
                            December
                        </option>
                </select>
            </div>
            <div class="form-group"><label asp-for="Year">Year</label>
             <select name="Year"" class="form-control">
                        <option value="2026" >
                            2026
                        </option>
                </select>
            </div>
            <div class="form-group"><label asp-for="Limit_amount">Amount ($)</label><input asp-for="Limit_amount" type="number" step="0.01" >
                <span asp-validation-for="Limit_amount" class="text-danger"></span>
            </div>
            <div style="display:flex; gap:16px;">
                <button type="submit" class="btn">Add Budget</button>
                <a asp-controller="Dashboard" asp-action="Index" class="btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}