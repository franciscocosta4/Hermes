@model Hermes.Models.BudgetViewModel
@{
    Layout = "_Layout";
}

@{
    var expense = Model?.MonthExpenseSum ?? 0;
    var budget = Model?.CurrentBudgetLimit ?? 0;
    var diff = Model?.DiffBudgetToExpense ?? 0;
    var percent = Model?.BudgetUsedPercentage ?? 0;

    if (percent < 0) percent = 0;
    if (percent > 100) percent = 100;
}

<div class="main-content">

    <div class="flex-between mb-2">
        <h2>Budgets Overview</h2>
    </div>

    <div class="grid-4">

        <!-- CARD PRINCIPAL -->
        <div class="card" style="grid-column: span 3;">

            <div class="flex-between">

                <div>
                    <div class="text-muted" style="font-size:0.8rem; text-transform:uppercase;">
                        Monthly Budget Usage
                    </div>

                    <div class="text-large">
                        $@expense
                        <span style="font-size:1rem; color:#7a7a7a;">
                            / $@budget
                        </span>
                    </div>
                </div>

                <div style="text-align:right;">
                    <div style="font-size:0.9rem; font-weight:500;">
                        $@diff left
                    </div>

                    <div style="font-size:0.8rem; color:#7a7a7a;">
                        @Math.Round(percent)% used
                    </div>
                </div>

            </div>

            <br />

            <!-- PROGRESS BAR -->
            <div style="
                width:100%;
                height:8px;
                background:#e6e6e6;
                border-radius:20px;
                overflow:hidden;
                ">
                <div style="
                    width:@percent.ToString(System.Globalization.CultureInfo.InvariantCulture)%;
                    height:8px;
                    background:#0b0b0b;
                    border-radius:20px;
                    transition: width 0.4s ease;
                    ">
                </div>
            </div>

        </div>

        <!-- ALERTS -->
        <div style="display:flex; flex-direction: column; gap: 14px;">

            @if (diff < 100 && diff > 0 && budget > 0)
            {
                <div class="card action-card" style="background:#fffef9; border-left:3px solid #fbc02d;">
                    <p style="color:#f57f17;">
                        <i class="fas fa-exclamation-triangle" style="margin-right:10px;"></i>
                        Close to budget (less than 100$ remaining)
                    </p>
                </div>
            }

            @if ((Model?.BudgetUsedPercentage ?? 0) > 100)
            {
                <div class="card action-card" style="background:#fdecea; border-left:3px solid #e53935;">
                    <p style="color:#b71c1c;">
                        <i class="fas fa-exclamation-circle" style="margin-right:10px;"></i>
                        Budget exceeded
                    </p>
                </div>
            }

        </div>

    </div>

    <br />

    <!-- BOTÕES -->
    <div style="display:flex; gap:16px;">

        <a asp-controller="Budget" asp-action="Create" class="btn">
            Add a new Budget
        </a>

        @if (Model?.CurrentBudgetId != null && Model.CurrentBudgetId > 0)
        {
            <form asp-controller="Budget" asp-action="Delete" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.CurrentBudgetId" />
                <button type="submit" class="btn btn-outline">
                    Give up on Current budget
                </button>
            </form>
        }

    </div>

    <!-- TABELA -->
    <div style="margin-top: 2.5rem;">

        <h3>All active budgets</h3>

        <div class="table-wrapper">

            <table>
                <thead>
                    <tr>
                        <th>Limit Amount</th>
                        <th>Month</th>
                        <th>Year</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model?.AllBudgets != null && Model.AllBudgets.Any())
                    {
                        foreach (var item in Model.AllBudgets)
                        {
                            <tr>
                                <td>@item.Limit_amount$</td>
                                <td>@item.Month</td>
                                <td>@item.Year</td>
                                <td>

                                    <form asp-controller="Budget" asp-action="Delete" method="post" style="display:inline;">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="id" value="@item.Id" />

                                        <button type="submit" style="background:none; border:none; padding:0;">
                                            <i class="far fa-trash-alt action-icon"></i>
                                        </button>
                                    </form>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" style="text-align:center; color:#7a7a7a;">
                                No budgets available
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>