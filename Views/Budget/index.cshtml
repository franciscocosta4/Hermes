<div class="main-content">
    <div class="flex-between mb-2">
        <h2> Budgets Overview</h2>
        <div>
            @* <a href="#" class="btn-outline btn-sm"><i class="fas fa-plus"></i> New</a> *@
        </div>
    </div>

    
    <div class="grid-4">
        <div class="card" style="grid-column: span 3;">

            <div class="flex-between">
                <div>
                    <div class="text-muted" style="font-size:0.8rem; text-transform:uppercase;">
                        Monthly Budget Usage
                    </div>
                    <div class="text-large">$1,850 <span style="font-size:1rem; color:#7a7a7a;">/ $2,000</span></div>
                </div>

                <div style="text-align:right;">
                    <div style="font-size:0.9rem; font-weight:500;">
                        $150 left
                    </div>
                    <div style="font-size:0.8rem; color:#7a7a7a;">
                        92% used
                    </div>
                </div>
            </div>

            <!-- PROGRESS BAR -->
            <div style="margin-top:14px; height:8px; background:#eee; border-radius:20px; overflow:hidden;">
                <div style="width:92%; height:8px; background:#0b0b0b; border-radius:20px;"></div>
            </div>

        </div>

        <div style="display:flex; flex-direction: column; gap: 14px;">
            <div class="card action-card" style=" background: #fffbee; border-left: 3px solid #fbc02d;">
                <div class="flex-between">
                    <div>
                        <i class="fas fa-exclamation-triangle" style="margin-right: 10px; color: #f9a825;"></i>
                        <strong style="color: #f57f17;">Close to your month budget!!</strong>
                        @* — Last 30 days: $1,850 vs month budget: $2,000 *@
                    </div>
                </div>
            </div>
            <div class="card action-card" style=" background: #fdecea; border-left: 3px solid #e53935;">
                <div class="flex-between">
                    <div>
                        <i class="fas fa-exclamation-circle" style="margin-right: 10px; color: #d32f2f;"></i>
                        <strong style="color: #b71c1c;">Budget exceeded</strong>
                        @* — Last 30 days: $1,850 vs month budget: $1,500 *@
                    </div>
                </div>
            </div>
        </div>
    </div>
    <br />
    <div style="display:flex; gap:16px;">
        <button type="submit" class="btn">Add a new Budget</button>
        <button type="submit" class="btn btn-outline">Give up on Current budget</button>
    </div>

    <div style="margin-top: 2.5rem;">
        <div class="flex-between">
            <h3>All active budgets <br /></h3>
        </div>

        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Limit Amount</th>
                        <th>Month</th>
                        <th>Year</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>$120</td>
                        <td>January</td>
                        <td>2026</td>
                        <td>
                            @* <a href="#"><i class="far fa-edit action-icon"></i></a> *@
                            <a href="#"><i class="far fa-trash-alt action-icon"></i></a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>