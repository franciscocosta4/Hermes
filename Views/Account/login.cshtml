@model LoginViewModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign in · Hermes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="css/style.css">
</head>
<body style="background:#fff;">
    <div class="container" style="max-width: 480px; padding-top: 6rem;">
        <div style="margin-bottom: 2.5rem;">
            <a href="index.html" style="font-weight:600; font-size:1.5rem; text-decoration:none; color:#0b0b0b;">Hermes</a>
        </div>
        <div class="card" style="padding: 2.5rem;">
            <h2 style="margin-bottom: 0.5rem;">Welcome back</h2>
            <p class="text-muted" style="margin-bottom: 2rem;">Sign in to your account</p>
            <form asp-action="Login" method="post">
                <div class="form-group">
                    <label>Email</label>
                    <input asp-for="Email" type="email" placeholder="m@example.com" required>
                    <span asp-validation-for="Email"></span>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input asp-for="Password" type="password" placeholder="••••••••" required>
                    <span asp-validation-for="Password"></span>
                </div>
                <button type="submit" class="btn" style="width:100%; padding:14px;">Sign in →</button>
            </form>
            <p style="margin-top: 1.8rem; text-align:center; font-size:0.9rem;">
                No account? <a asp-controller="Account" asp-action="Register" style="color:#0b0b0b; font-weight:500;">Register</a>
            </p>
        </div>
    </div>
</body>
</html>