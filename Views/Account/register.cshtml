@model RegisterViewModel
@{
    Layout = "_LayoutLanding"; // usamos o layout da landing page pois não queremos sidebar

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register · Hermes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="css/style.css">
</head>
<body style="background:#fff;">
    <div class="container" style="max-width: 480px; padding-top: 6rem;">
        <div style="margin-bottom: 2.5rem;">
            <a asp-controller="Home" asp-action="Index" style="font-weight:600; font-size:1.5rem; text-decoration:none; color:#0b0b0b;">Hermes</a>
        </div>
        <div class="card" style="padding: 2.5rem;">
            <h2 style="margin-bottom: 0.5rem;">Create account</h2>
            <p class="text-muted" style="margin-bottom: 2rem;">Start tracking in seconds</p>
            <form asp-action="Register" method="post">
                  @Html.AntiForgeryToken()
                <div class="form-group">
                    <label>Full name</label>
                    <input asp-for="FullName" type="text" placeholder="Alex Rivera" required>
                </div>
                <div class="form-group">
                    <label>User Name</label>
                    <input asp-for="UserName" type="text" placeholder="Alex_0" required>
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" placeholder="alex@hermes.app" asp-for="Email" required>
                    <span asp-validation-for="Email"></span>
                </div>
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" asp-for="Password"  placeholder="At least 8 characters" required>
                    <span asp-validation-for="Password"></span>
                </div>
                <div class="form-group">
                    <label>Confirm Password</label>
                    <input type="password" asp-for="ConfirmPassword"  placeholder="At least 8 characters" required>
                    <span asp-validation-for="ConfirmPassword"></span>
                </div>
                <div asp-validation-summary="All"></div>
                <button type="submit" class="btn" style="width:100%; padding:14px;">Register →</button>
            </form>
            <p style="margin-top: 1.8rem; text-align:center; font-size:0.9rem;">
                Already have an account? <a asp-controller="Account" asp-action="Login" style="color:#0b0b0b; font-weight:500;">Sign in</a>
            </p>
        </div>
    </div>
</body>
</html>
}