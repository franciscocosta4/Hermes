@model Hermes.Models.SavingsGoalViewModel
@{
    Layout = "_Layout";
}


<div class="main-content">

    <div class="flex-between mb-2">
        <h2>Savings Goals</h2>
    </div>

    <div class="grid-4">
        <!-- ALERTS E INFO -->
        <div style="display:flex; flex-direction: column; gap: 14px;">

            @if (Model?.AllGoals != null && Model.AllGoals.Any())
            {
                foreach (var item in Model.AllGoals)
                {
                    bool IsCompleted = item.Target_amount == item.Current_amount;
                    bool IsCloseToCompletion = (item.Target_amount - item.Current_amount) <= (item.Target_amount * 0.10m);
                
                    @if (IsCompleted)
                    {
                        <div class="card action-card" style="background:#f4faf0; border-left:3px solid #2e7d32;">
                            <p style="color:#1b5e20;">
                                <i class="fas fa-check-circle" style="margin-right:10px;"></i>
                                A Goal is completed!
                            </p>
                        </div>
                    }
                    else if (IsCloseToCompletion)
                    {
                        <div class="card action-card" style="background:#fffef9; border-left:3px solid #fbc02d;">
                            <p style="color:#f57f17;">
                                <i class="fas fa-flag-checkered" style="margin-right:10px;"></i>
                                Almost there! Less than 10% remaining
                            </p>
                        </div>
                    }
                }
            }
            else
            {
                <div class="card action-card" style="background:#fafafa; border-left:3px solid #9e9e9e;">
                    <p style="color:#424242;">
                        <i class="fas fa-bullseye" style="margin-right:10px;"></i>
                        Create a savings goal to start tracking
                    </p>
                </div>
            }

        </div>
    </div>

    <br />

    <!-- BOTÕES DE AÇÃO -->
    <div style="display:flex; gap:16px;">

        <a asp-controller="SavingsGoal" asp-action="Create" class="btn">
            Add a new Savings Goal
        </a>
    </div>

    <!-- TABELA COM TODOS OS GOALS -->
    <div style="margin-top: 2.5rem;">

        <h3>Your goals</h3>

        <div class="table-wrapper">

            @if (Model?.AllGoals != null && Model.AllGoals.Any())
            {
                foreach (var item in Model.AllGoals)
                {
                    var itemPercent = item.Target_amount > 0 ? Math.Round((item.Current_amount / item.Target_amount) * 100) : 0;
                    var itemRemainingAmount = item.Target_amount - item.Current_amount;
                    <!-- CARD PRINCIPAL DO GOAL ATUAL -->
                    <div class="card" style="grid-column: span 3;">

                        <div class="flex-between">

                            <div>
                                <div class="text-muted" style="font-size:0.8rem; text-transform:uppercase;">
                                    @(item.Name ?? "No active goal")
                                </div>

                                <div class="text-large">
                                    $@item.Current_amount.ToString("N0")
                                    <span style="font-size:1rem; color:#7a7a7a;">
                                        / $@item.Target_amount.ToString("N0")
                                    </span>
                                </div>
                            </div>

                            <div style="text-align:right;">
                                <div style="font-size:0.9rem; font-weight:500;">
                                    $@itemRemainingAmount.ToString("N0") left
                                </div>

                                <div style="font-size:0.8rem; color:#7a7a7a;">
                                    @Math.Round(itemPercent)% saved
                                </div>
                                <br/>
                            <form asp-controller="SavingsGoal" asp-action="Delete" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-outline">
                                    Remove goal
                                </button>
                            </form>
                            </div>
                        </div>

                        <!-- Regras de alocação visíveis -->
                        @if (item?.percentage_of_income != null || item?.minimum_balance_to_keep != null)
                        {
                            <div style="margin-top: 1rem; display: flex; gap: 1.5rem; font-size: 0.85rem; color: #5e5e5e;">
                                @if (item.percentage_of_income != null)
                                {
                                    <div>
                                        <i class="fas fa-percent" style="margin-right: 6px;"></i>
                                        <strong>@item.percentage_of_income%</strong> of each income
                                    </div>
                                }
                                @if (item?.minimum_balance_to_keep != null)
                                {
                                    <div>
                                        <i class="fas fa-shield-alt" style="margin-right: 6px;"></i>
                                        Keep <strong>$@item.minimum_balance_to_keep?.ToString("N0")</strong> in balance
                                    </div>
                                }
                            </div>
                        }
                        <br />
                        <!-- PROGRESS BAR -->
                        <div style="
                            width:100%;
                            height:8px;
                            background:#e6e6e6;
                            border-radius:20px;
                            overflow:hidden;
                            ">
                            <div style="
                                width:@itemPercent.ToString(System.Globalization.CultureInfo.InvariantCulture)%;
                                height:8px;
                                background:#0b0b0b;
                                border-radius:20px;
                                transition: width 0.4s ease;
                                ">
                            </div>
                        </div>

                    </div>
                    <br />
                }
            }
            else
            {
                <p colspan="7" style="text-align:center; color:#7a7a7a;">
                    No savings goals yet
                </p>
            }

        </div>
    </div>

</div>