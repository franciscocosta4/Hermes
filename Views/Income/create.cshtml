@model Hermes.Models.IncomeViewModel
@{
    Layout = "_Layout";
}
<div class="main-content" style="max-width:600px;">
    <div class="card">
        <h3>Record income</h3>
        <br />
        <form asp-action="Create" method="post" >
            @Html.AntiForgeryToken()
            @* <div class="form-group"><label>Source</label><input name="source" placeholder="Salary / Freelance" required>
            </div> *@
            <div class="form-group"><label  asp-for="Amount">Amount ($)</label><input asp-for="Amount" type="number" step="0.01"  required>
            <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <div class="form-group"><label asp-for="Date">Date</label><input asp-for="Date" type="date" required></div>
            <span asp-validation-for="Date" class="text-danger"></span>
            <div style="display:flex; gap:16px;">
                <button type="submit" class="btn">Add income</button>
                <a asp-controller="Dashboard" asp-action="Index" class="btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}   