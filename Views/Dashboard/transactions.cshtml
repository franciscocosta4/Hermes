<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transactions · Hermes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
<div class="app-grid">
    <div class="sidebar">
        <div style="font-weight: 600; font-size: 1.6rem; margin-bottom: 2.5rem;">Hermes</div>
        <nav>
            <a href="dashboard.html" class="nav-item"><i class="fas fa-home"></i> Dashboard</a>
            <a href="transactions.html" class="nav-item active"><i class="fas fa-list-ul"></i> Transactions</a>
            <a href="add-expense.html" class="nav-item"><i class="fas fa-minus-circle"></i> Add expense</a>
            <a href="add-income.html" class="nav-item"><i class="fas fa-plus-circle"></i> Add income</a>
        </nav>
    </div>
    <div class="main-content">
        <div class="flex-between mb-2">
            <h2>All transactions</h2>
            <div>
                <a href="add-expense.html" class="btn-outline btn-sm">+ Expense</a>
                <a href="add-income.html" class="btn-outline btn-sm" style="margin-left:8px;">+ Income</a>
            </div>
        </div>
        <div class="card" style="padding:1.2rem;">
            <div style="display:flex; gap:16px;">
                <input placeholder="Filter by description..." style="width:auto; flex:1;">
                <select style="width:auto;"><option>All categories</option><option>Food</option><option>Housing</option></select>
            </div>
        </div>
        <div class="table-wrapper">
            <table>
                <thead><tr><th>Amount</th><th>Date</th><th>Description</th><th>Category</th><th></th></tr></thead>
                <tbody>
                    <tr><td class="type-expense">-$75.50</td><td>Today</td><td>Groceries</td><td>Food</td><td><a href="#"><i class="far fa-edit action-icon"></i></a><a href="#"><i class="far fa-trash-alt action-icon"></i></a></td></tr>
                    <tr><td class="type-income">+$2,400</td><td>Mar 28</td><td>Salary</td><td>Income</td><td><a href="#"><i class="far fa-edit action-icon"></i></a></td></tr>
                    <tr><td class="type-expense">-$45.00</td><td>Mar 27</td><td>Internet</td><td>Utilities</td><td><a href="#"><i class="far fa-edit action-icon"></i></a><a href="#"><i class="far fa-trash-alt action-icon"></i></a></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
</body>
</html>