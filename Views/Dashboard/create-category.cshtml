@model Hermes.Models.CategoryViewModel
@{
    Layout = "_Layout";
}
<div class="main-content" style="max-width:600px;">
    <div class="card">
        <h3>Add a category for your expenses</h3>
        <br />
        <form asp-action="Create" method="post" >
            @Html.AntiForgeryToken()
            @* <div class="form-group"><label>Source</label><input name="source" placeholder="Salary / Freelance" required>
            </div> *@
            <div class="form-group"><label  asp-for="Name">Name</label><input asp-for="Name" type="name" step="0.01"  required>
            <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div style="display:flex; gap:16px;">
                <button type="submit" class="btn">Add Category</button>
                <a asp-controller="Dashboard" asp-action="Index" class="btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}   