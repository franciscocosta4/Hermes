@model Hermes.Models.IncomeViewModel

@{
    Layout = "_Layout";
}
<div class="main-content" style="max-width:600px;">
    <div class="card">
        <h3>Record income</h3>
        <form method="post" action="dashboard.html">
            <div class="form-group"><label>Source</label><input name="source" placeholder="Salary / Freelance" required>
            </div>
            <div class="form-group"><label>Amount ($)</label><input type="number" step="0.01" name="amount" required>
            </div>
            <div class="form-group"><label>Date</label><input type="date" name="date" required></div>
            <div style="display:flex; gap:16px;">
                <button type="submit" class="btn">Add income</button>
                <a asp-controller="Dashboard" asp-action="Index" class="btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div>
