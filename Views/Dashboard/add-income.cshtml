<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add income · Hermes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
<div class="app-grid">
    <div class="sidebar">
        <div style="font-weight:600;">Hermes</div>
        <nav><a href="dashboard.html" class="nav-item"><i class="fas fa-arrow-left"></i> Back</a></nav>
    </div>
    <div class="main-content" style="max-width:600px;">
        <div class="card">
            <h3>Record income</h3>
            <form method="post" action="dashboard.html">
                <div class="form-group"><label>Source</label><input name="source" placeholder="Salary / Freelance" required></div>
                <div class="form-group"><label>Amount ($)</label><input type="number" step="0.01" name="amount" required></div>
                <div class="form-group"><label>Date</label><input type="date" name="date" required></div>
                <div style="display:flex; gap:16px;">
                    <button type="submit" class="btn">Add income</button>
                    <a href="dashboard.html" class="btn-outline">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
</body>
</html>