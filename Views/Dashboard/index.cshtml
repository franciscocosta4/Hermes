@model Hermes.Models.UserHeaderViewModel
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard · Hermes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600&display=swap"
          rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="css/style.css">
</head>

<body class="dashboard">
    <div class="app-grid">
        <div class="sidebar">
            <div
                style="font-weight: 600; font-size: 1.6rem; letter-spacing: -0.03em; margin-bottom: 2.5rem; padding-left: 8px;">
                Hermes</div>
                <nav>
                    <a href="dashboard.html" class="nav-item active"><i class="fas fa-home"></i> Dashboard</a>
                    <a href="transactions.html" class="nav-item"><i class="fas fa-list-ul"></i> Transactions</a>
                    <a href="add-expense.html" class="nav-item"><i class="fas fa-minus-circle"></i> Add expense</a>
                    <a href="add-income.html" class="nav-item"><i class="fas fa-plus-circle"></i> Add income</a>
                    <a href="#" class="nav-item" onclick="return false;"><i class="fas fa-chart-pie"></i> Reports</a>
                    <a href="#" class="nav-item" onclick="return false;"><i class="fas fa-cog"></i> Settings</a>
                </nav>
                <div style="margin-top: 3rem; border-top: 1px solid #ddd; padding-top: 1.5rem;">
                    <div style="display:flex; align-items:center; gap:10px;">
                        <div
                            style="width:32px; height:32px; background:#0b0b0b; border-radius:40px; display:flex; align-items:center; justify-content:center; color:white;">
                            @(Model?.FullName?[0].ToString().ToUpper() ?? "U")</div>
                            <div><strong> @(Model?.FullName ?? "User")</strong><br><span class="text-muted"
                                                                                             style="font-size:0.8rem;">@Model?.Email</span></div>
                            </div>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn-outline btn-sm">
                                    Logout
                                </button>
                            </form>
                        </div>
                    </div>

                    <div class="main-content">
                        <div class="flex-between mb-2">
                            <h2>Overview</h2>
                            <div>
                                <a href="add-expense.html" class="btn-outline btn-sm"><i class="fas fa-plus"></i> New</a>
                                <a href="#" class="btn-outline btn-sm" style="margin-left:8px;"><i class="fas fa-download"></i>
                                    CSV</a>
                                </div>
                            </div>

                            <div class="grid-4">
                                <div class="card">
                                    <div class="text-muted" style="font-size:0.8rem; text-transform:uppercase;">Balance (30d)</div>
                                    <div class="text-large">$4,250</div>
                                    <span style="color:#0b0b0b;">↑ 12% vs last month</span>
                                </div>
                                <div class="card">
                                    <div class="text-muted" style="font-size:0.8rem; text-transform:uppercase;">Income (30d)</div>
                                    <div class="text-large">$8,420</div>
                                    <span class="text-muted">+ $1,200 sponsorship</span>
                                </div>
                                <div class="card">
                                    <div class="text-muted" style="font-size:0.8rem; text-transform:uppercase;">Expenses (30d)</div>
                                    <div class="text-large">$4,170</div>
                                    <span class="text-muted">vs avg $3,880</span>
                                </div>
                                <div class="card" style="border-left: 4px solid #0b0b0b;">
                                    <div class="text-muted" style="font-size:0.8rem; text-transform:uppercase;">90d avg expense</div>
                                    <div class="text-large">$3,880</div>
                                    <span class="badge badge-light" style="margin-top:8px;">overspending alert</span>
                                </div>
                            </div>

                            <div class="card" style="margin-top: 24px; background: #f9f9f9;">
                                <div class="flex-between">
                                    <div><i class="fas fa-exclamation-triangle" style="margin-right: 10px;"></i> <strong>Overspending
                                        detected</strong> — Last 30 days: $4,170 vs 90d avg $3,880 (+7.5%)</div>
                                        <span class="badge">review</span>
                                    </div>
                                </div>

                                <div style="margin-top: 2.5rem;">
                                    <div class="flex-between">
                                        <h3>Recent transactions</h3>
                                        <a href="transactions.html" style="color:#0b0b0b; font-weight:500;">View all →</a>
                                    </div>
                                    <div class="table-wrapper">
                                        <table>
                                            <thead>
                                                <tr>
                                                    <th>Amount</th>
                                                    <th>Date</th>
                                                    <th>Type</th>
                                                    <th>Category</th>
                                                    <th>Account</th>
                                                    <th></th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr>
                                                    <td class="type-expense">- $1,000</td>
                                                    <td>01/02/2022</td>
                                                    <td>Withdrawal</td>
                                                    <td>Rent</td>
                                                    <td>Mastercard 1145</td>
                                                    <td><a href="#"><i class="far fa-edit action-icon"></i></a><a href="#"><i
                                                        class="far fa-trash-alt action-icon"></i></a></td>
                                                    </tr>
                                                    <tr>
                                                        <td class="type-expense">- $300</td>
                                                        <td>03/01/2022</td>
                                                        <td>Withdrawal</td>
                                                        <td>Food</td>
                                                        <td>PayPal</td>
                                                        <td><a href="#"><i class="far fa-edit action-icon"></i></a><a href="#"><i
                                                            class="far fa-trash-alt action-icon"></i></a></td>
                                                        </tr>
                                                        <tr>
                                                            <td class="type-income">+ $1,000</td>
                                                            <td>29/11/2021</td>
                                                            <td>Sponsorship</td>
                                                            <td>Income</td>
                                                            <td>-</td>
                                                            <td><a href="#"><i class="far fa-edit action-icon"></i></a></td>
                                                        </tr>
                                                        <tr>
                                                            <td class="type-income">+ $300</td>
                                                            <td>16/10/2021</td>
                                                            <td>Sponsorship</td>
                                                            <td>Income</td>
                                                            <td>-</td>
                                                            <td><a href="#"><i class="far fa-edit action-icon"></i></a></td>
                                                        </tr>
                                                        <tr>
                                                            <td class="type-expense">- $3,500</td>
                                                            <td>02/09/2021</td>
                                                            <td>Withdrawal</td>
                                                            <td>Travel</td>
                                                            <td>Mastercard 1145</td>
                                                            <td><a href="#"><i class="far fa-edit action-icon"></i></a><a href="#"><i
                                                                class="far fa-trash-alt action-icon"></i></a></td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                            <div style="margin-top: 2rem; display: flex; gap: 24px;">
                                                <div
                                                    style="flex:1; height: 80px; background: #f4f4f4; border-radius: 18px; display: flex; align-items: flex-end; padding: 10px;">
                                                    <div style="width: 12%; background:#0b0b0b; height: 60%; margin-right: 4px; border-radius: 40px;">
                                                    </div>
                                                    <div style="width: 12%; background:#0b0b0b; height: 80%; margin-right: 4px; border-radius: 40px;">
                                                    </div>
                                                    <div style="width: 12%; background:#0b0b0b; height: 45%; margin-right: 4px; border-radius: 40px;">
                                                    </div>
                                                    <div style="width: 12%; background:#0b0b0b; height: 90%; margin-right: 4px; border-radius: 40px;">
                                                    </div>
                                                    <div style="width: 12%; background:#0b0b0b; height: 70%; border-radius: 40px;"></div>
                                                    <span class="text-muted" style="margin-left: 12px;">Last 5 months</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </body>

                            </html>